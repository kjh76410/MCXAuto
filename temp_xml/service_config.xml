<?xml version="1.0" encoding="UTF-8"?>
<service-configuration-info etag="MDkxODM0MDAwMDAw"  xmlns="urn:3gpp:ns:mcpttServiceConfig:1.0">
    <service-configuration-params domain="ims.mnc001.mcc001.3gppnetwork.org">
        <common>
            <anyExt>
                <mcdata>
                    <time-temp-data-waiting>PT0S</time-temp-data-waiting>
                </mcdata>
            </anyExt>
        </common>
        <on-network>
            <private-call>
                <hang-time>PT30S</hang-time>
                <max-duration-with-floor-control>PT0S</max-duration-with-floor-control>
                <max-duration-without-floor-control>PT0S</max-duration-without-floor-control>
            </private-call>
            <fc-timers-counters>
                <T1-end-of-rtp-media>PT5S</T1-end-of-rtp-media>
                <T3-stop-talking-grace>PT5S</T3-stop-talking-grace>
                <T7-floor-idle>PT0S</T7-floor-idle>
                <T8-floor-revoke>PT0S</T8-floor-revoke>
                <T11-end-of-RTP-dual>PT0S</T11-end-of-RTP-dual>
                <T12-stop-talking-dual>PT0S</T12-stop-talking-dual>
                <T15-conversation>PT60S</T15-conversation>
                <T16-map-group-to-bearer>PT0S</T16-map-group-to-bearer>
                <T17-unmap-group-to-bearer>PT0S</T17-unmap-group-to-bearer>
                <T20-floor-granted>PT0S</T20-floor-granted>
                <T55-connect>PT0S</T55-connect>
                <T56-disconnect>PT0S</T56-disconnect>
                <C7-floor-idle>0</C7-floor-idle>
                <C17-unmap-group-to-bearer>0</C17-unmap-group-to-bearer>
                <C20-floor-granted>0</C20-floor-granted>
                <C55-connect>0</C55-connect>
                <C56-disconnect>0</C56-disconnect>
            </fc-timers-counters>
            <signalling-protection>
                <confidentiality-protection>false</confidentiality-protection>
                <integrity-protection>false</integrity-protection>
            </signalling-protection>
            <protection-between-mcptt-servers>
                <allow-signalling-protection>false</allow-signalling-protection>
                <allow-floor-control-protection>false</allow-floor-control-protection>
            </protection-between-mcptt-servers>
            <emergency-resource-priority>
                <resource-priority-namespace>mcpttp.7</resource-priority-namespace>
                <resource-priority-priority>7</resource-priority-priority>
            </emergency-resource-priority>
            <imminent-peril-resource-priority>
                <resource-priority-namespace>mcpttp.6</resource-priority-namespace>
                <resource-priority-priority>6</resource-priority-priority>
            </imminent-peril-resource-priority>
            <normal-resource-priority>
                <resource-priority-namespace>mcpttp.5</resource-priority-namespace>
                <resource-priority-priority>5</resource-priority-priority>
            </normal-resource-priority>
            <anyExt>
                <emergency-call-max-duration-floor-control>10</emergency-call-max-duration-floor-control>
                <tx-and-rx-control>
                    <max-data-size-sds-bytes>1000</max-data-size-sds-bytes>
                    <max-data-size-fd-bytes>10485760</max-data-size-fd-bytes>
                </tx-and-rx-control>
                <file-availability>
                    <default-file-availability>86400</default-file-availability>
                    <max-file-availability>86400</max-file-availability>
                </file-availability>
                <adhoc-group-call>
                    <allow-adhoc-group-call-support>true</allow-adhoc-group-call-support>
                    <max-no-participants>1000</max-no-participants>
                    <hang-time>PT60S</hang-time>
                    <max-duration-of-call>PT3600S</max-duration-of-call>
                </adhoc-group-call>
            </anyExt>
        </on-network>
    </service-configuration-params>
</service-configuration-info>
